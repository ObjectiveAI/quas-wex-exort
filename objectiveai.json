    "linux": { "x86_64": "quas-wex-exort-linux-x86_64.zip", "aarch64": "quas-wex-exort-linux-aarch64.zip" },
    "macos": { "x86_64": "quas-wex-exort-macos-x86_64.zip", "aarch64": "quas-wex-exort-macos-aarch64.zip" }
  },
  "mcp_servers": [
    { "name": "quas-wex-exort", "authorization": false }
