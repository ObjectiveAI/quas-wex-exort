{
  "owner": "ObjectiveAI",
  "name": "quas-wex-exort",
  "version": "0.1.0",
  "description": "Programmatic invocation of MCP tools and the ObjectiveAI CLI for ObjectiveAI agents.",
  "daemon": true,
  "exec": {
